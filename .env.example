# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=sqlite:///data/predictions.db

# Model Configuration
MODEL_PATH=models/disease_model.h5
CONFIDENCE_THRESHOLD=0.5

# Server Configuration
HOST=0.0.0.0
PORT=5000

# CORS Configuration
ALLOWED_ORIGINS=*